[Unit]
Description=Katafract Node Agent
After=network.target wg-quick@wg0.service
Wants=wg-quick@wg0.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/katafract
EnvironmentFile=/opt/katafract/.env
ExecStart=/usr/bin/python3 /opt/katafract/agent/agent.py
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
