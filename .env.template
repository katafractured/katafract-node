# Katafract Node Environment Variables
# This file is a template — never commit a populated .env
# Values are injected by Artemis at provisioning time

# Node identity
NODE_ID=fra-01
SITE=fra
REGION=eu-west
SEQUENCE=1
TIER=primary

# Network — assigned by provider
IPV4_ADDRESS=
IPV6_ADDRESS=
IPV6_BLOCK=

# WireGuard
WG_LISTEN_PORT=51820
WG_PRIVATE_KEY=
WG_IPV4_TUNNEL=10.10.1.1/24
WG_IPV6_TUNNEL=fd00:katafract:fra::1/64

# Artemis connection
ARTEMIS_API_URL=https://api.katafract.com
ARTEMIS_NODE_TOKEN=

# DNS upstream (DoT)
DNS_UPSTREAM_1=1.1.1.1
DNS_UPSTREAM_2=9.9.9.9
DNS_UPSTREAM_PORT=853

# Blocklist sources
BLOCKLIST_URL_1=https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts
BLOCKLIST_URL_2=https://raw.githubusercontent.com/hagezi/dns-blocklists/main/hosts/multi.txt

# Traffic shaping thresholds (bytes/day — Artemis can override via desired-state)
PEER_WARN_BYTES_DAY=32212254720
PEER_THROTTLE_BYTES_DAY=160000000000
PEER_DISCONNECT_BYTES_DAY=322122547200
PEER_SUSPEND_BYTES_DAY=644245094400
THROTTLE_RATE_MBPS=10
ABUSE_SUSTAINED_MBPS=200
ABUSE_SUSTAINED_SECONDS=1800
