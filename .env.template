# Katafract WraithGate Node — Environment Template
# Pass these as env vars to bootstrap.sh, not as a file
# See bootstrap.sh usage comment for details

# ── Node identity ─────────────────────────────────────────────
NODE_ID=vpn-xx-01              # unique ID — matches node_id in artemis DB
SITE=City                      # human-readable city name (Frankfurt, Helsinki, etc.)
REGION=eu-west                 # region slug (eu-west | eu-north | ap-southeast | us-central)

# ── Network ───────────────────────────────────────────────────
WG_LISTEN_PORT=51820
WG_PRIVATE_KEY=                # output of: wg genkey
WG_IPV4_TUNNEL=10.10.X.1/24   # server interface — .1 of the client subnet

# ── Mesh enrollment ───────────────────────────────────────────
HEADSCALE_PREAUTH_KEY=         # from Infisical /nodes → HEADSCALE_PREAUTH_KEY (reusable)

# ── Artemis heartbeat ─────────────────────────────────────────
NODE_AGENT_TOKEN=              # from Infisical /artemis → NODE_AGENT_TOKEN
ARTEMIS_HEARTBEAT_URL=http://100.64.0.1/internal/nodes/heartbeat
